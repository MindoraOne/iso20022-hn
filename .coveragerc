# Coverage.py configuration for Pain001
# Enforces 99% branch coverage floor with per-module precision

[run]
# Python version
python_version = 3.9

# Source code to measure
source = pain001

# Files to omit from coverage
omit =
    */site-packages/*
    */distutils/*
    */__main__.py
    */conftest.py

# Branch coverage (mandatory for quality gate)
branch = true

# Parallel mode for test concurrency (xdist support)
parallel = true
concurrency = multiprocessing

# Ignore errors in __init__.py (fixture only)
include =
    pain001/**/*.py

[report]
# Precision (3 decimal places)
precision = 3

# Skip covered lines in output
skip_covered = false

# Skip empty files
skip_empty = true

# Exclude lines from coverage (docstrings, debug only)
exclude_lines =
    pragma: no cover
    def __repr__
    if __name__ == .__main__.:
    raise AssertionError
    raise NotImplementedError
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    @overload
    if False:
    if true:
    if 0:
    \.\.\.$
    pass$
    \s*\.\.\.\s*$

# Ignore entirely (rare cases)
omit =
    */site-packages/*
    */distutils/*

# Per-module enforcement (99% minimum, 100% for critical)
[paths]
source =
    pain001
    */site-packages/pain001

# Module fail-thresholds (enforce 99% minimum across all modules)
[html]
# HTML report output directory
directory = htmlcov
title = Pain001 Coverage Report

[xml]
# XML report for CI/CD integration
# Generated to coverage.xml for GitHub/SonarQube

# PySentinel enforcement: NEVER relax these thresholds
# If a module drops below 99%, halt and investigate before proceeding
# New code MUST hit 100% branch coverage
# Regressing coverage triggers automatic failure in CI/CD
