# Configuracion de la API local (pain001/api/app_local.py), leida via
# pydantic-settings (pain001/api/local/settings.py). Todo es OPCIONAL: si una
# variable no esta seteada, se usa el default indicado abajo.

# Puerto de la API local. Usado por Settings.port y por el arranque de uvicorn
# en el Dockerfile (CMD ... --port ${PORT:-8000}) y docker-compose.yml.
PORT=8000

# Interfaz de bind para el arranque local (uvicorn --host). En contenedor
# siempre es 0.0.0.0 (ver Dockerfile).
HOST=0.0.0.0

# Origenes permitidos por CORS, coma-separado. "*" abre a cualquier origen
# (CORSMiddleware en app_local.py via Settings.cors_origins_list).
CORS_ORIGINS=*

# Limite del CSV subido en POST /api/v1/local/hn/generate, en bytes
# (5 MB por defecto). Settings.max_body_size en
# pain001/api/local/constants.py (MAX_FILE_SIZE).
MAX_BODY_SIZE=5242880

# Rate limiting (sintaxis de slowapi, decorador @limiter.limit en cada ruta
# de pain001/api/app_local.py), leido desde Settings:
#   GET  /api/v1/health                 -> Settings.rate_limit_health
#   GET  /api/v1/local/hn/templates     -> Settings.rate_limit_templates
#   POST /api/v1/local/hn/generate      -> Settings.rate_limit_generate
RATE_LIMIT_HEALTH=60/minute
RATE_LIMIT_TEMPLATES=30/minute
RATE_LIMIT_GENERATE=10/minute

# Nivel de logging: DEBUG, INFO, WARNING, ERROR. Usado por
# logging.basicConfig() en app_local.py via Settings.log_level.
LOG_LEVEL=INFO

# Subcarpeta de banco activa dentro de pain001/templates/local/ (hoy solo
# existe "bancatlan"). Usada para construir LOCAL_TEMPLATE_ROOT en
# pain001/api/local/constants.py via Settings.local_template_bank.
LOCAL_TEMPLATE_BANK=bancatlan

# Directorio temporal donde se escriben los CSV subidos antes de parsearlos
# (validators.save_to_temp). Default (si no se setea): "<cwd>/tmp", relativo
# al directorio desde el que se arranca el proceso -- NO tempfile.gettempdir()
# (ej. /tmp), porque pain001.data.loader valida toda ruta de datos anclada a
# os.getcwd() (pain001/security/path_validator.py) y un TEMP_DIR fuera del cwd
# hace que el CSV recien subido sea rechazado como violacion de seguridad. En
# el contenedor el Dockerfile lo fija explicitamente a /app/tmp (ENV TEMP_DIR),
# que coincide con el WORKDIR /app.
TEMP_DIR=/app/tmp
